{
  "name": "peek-and-map",
  "displayName": "Peek and Map",
  "description": "Provide two views to peek definition and map relationship",
  "version": "1.3.3",
  "publisher": "asong",
  "icon": "media/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/asong-w/peek-and-map"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "peekPanel",
          "title": "Peek",
          "icon": "$(symbol-method)"
        },
        {
          "id": "mapPanel",
          "title": "Map",
          "icon": "$(references)"
        },
        {
          "id": "symbolPanel",
          "title": "Symbol",
          "icon": "$(search)"
        }
      ]
    },
    "views": {
      "peekPanel": [
        {
          "type": "webview",
          "id": "peekView.view",
          "name": "Peek View",
          "icon": "media/icon.png"
        }
      ],
      "mapPanel": [
        {
          "type": "webview",
          "id": "mapView.view",
          "name": "Map View",
          "icon": "media/icon.png"
        }
      ],
      "symbolPanel": [
        {
          "type": "webview",
          "id": "symbolSearch.view",
          "name": "Symbol Search",
          "icon": "media/icon.png"
        }
      ]
    },
    "commands": [
      {
        "command": "peekView.reveal",
        "title": "Peek and Map: Show Peek View"
      },
      {
        "command": "mapView.reveal",
        "title": "Peek and Map: Show Map View"
      },
      {
        "command": "symbolSearch.reveal",
        "title": "Peek and Map: Show Symbol Search"
      }
    ],
    "configuration": {
      "title": "Peek and Map",
      "properties": {
        "peekView.fontSize": {
          "type": "number",
          "default": 13,
          "description": "Peek 视图字体大小（px）"
        },
        "peekView.contextPadding": {
          "type": "number",
          "default": 30,
          "minimum": 0,
          "maximum": 500,
          "description": "在符号定义体上下额外显示的行数（范围 0–500；方便查看更多上下文）"
        },
        "mapView.wheelPanSensitivity": {
          "type": "number",
          "default": 1,
          "minimum": 0.05,
          "maximum": 5,
          "description": "Map 图形视图中鼠标滚轮滚动平移灵敏度（范围0.05-5 默认值 1）"
        },
        "mapView.wheelTiltPanSensitivity": {
          "type": "number",
          "default": 0.3,
          "minimum": 0.05,
          "maximum": 5,
          "description": "Map 图形视图中鼠标滚轮左右拨动平移灵敏度（范围0.05-5 默认值 0.3）"
        },
        "mapView.singleClickAction": {
          "type": "string",
          "default": "peekOnly",
          "enum": [
            "peekOnly",
            "jumpTo"
          ],
          "enumDescriptions": [
            "单击仅更新 Peek 视图",
            "单击同时更新 Peek 并打开编辑器"
          ],
          "description": "Map 视图节点单击行为"
        },
        "symbolSearch.singleClickAction": {
          "type": "string",
          "default": "peekOnly",
          "enum": [
            "peekOnly",
            "jumpTo"
          ],
          "enumDescriptions": [
            "单击仅更新 Peek 视图",
            "单击同时更新 Peek 并打开编辑器"
          ],
          "description": "Symbol Search 结果单击行为"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx @vscode/vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@types/prismjs": "^1.26.6",
    "prismjs": "^1.30.0"
  }
}
